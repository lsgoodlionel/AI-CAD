# ── 数据库 ───────────────────────────────────────────────────
DATABASE_URL=postgresql://cad_user:cad_pass@localhost:5432/cad_db
REDIS_URL=redis://localhost:6379/0

# ── 文件存储（MinIO）────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=cad_minio
MINIO_SECRET_KEY=cad_minio_pass
MINIO_BUCKET_DRAWINGS=drawings
MINIO_BUCKET_REPORTS=reports
MINIO_USE_SSL=false

# ── 向量数据库（Chroma）─────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8100

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_DAYS=30

# ── AI 服务 ─────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001

# ── LLM API Keys（模型路由从 DB 读取环境变量名后，从此处取值）──
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
# Ollama 无需 API Key，只需在提供商配置中填写 base_url

# ── 企业微信通知（可选，留空则静默跳过）──────────────────────
WECHAT_WEBHOOK_URL=

# ── 模型路由缓存 TTL（秒）────────────────────────────────────
MODEL_ROUTER_CACHE_TTL_SEC=30
